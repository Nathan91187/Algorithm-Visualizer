<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Slider?>

<BorderPane fx:id="root" xmlns:fx="http://javafx.com/fxml" fx:controller="sorts.SelectionSort"
            style="-fx-background-color: linear-gradient(to bottom, #121212, #000000);">

    <!-- Top: Back button aligned top-right -->


    <!-- Center: Visualization pane -->
    <center>
        <Pane fx:id="visualPane"/>
    </center>

    <!-- Bottom: Controls truly floating with no grey -->
    <bottom>
        <StackPane style="-fx-padding: 10; -fx-background-color: transparent;" alignment="CENTER">
            <HBox spacing="10" alignment="CENTER" style="-fx-background-color: transparent;">
                <Button fx:id="startBtn" text="Start"
                        style="
                            -fx-background-color: linear-gradient(to bottom, #e0e0e0, #a0a0a0);
                            -fx-text-fill: #000000;
                            -fx-font-weight: bold;
                            -fx-font-size: 14px;
                            -fx-background-radius: 10px;
                            -fx-border-color: #999999;
                            -fx-border-width: 2px;
                            -fx-padding: 8 20 8 20;
                            -fx-effect: dropshadow( gaussian , rgba(0,0,0,0.4) , 4, 0, 0, 2 );
                        "/>
                <Slider fx:id="speedSlider" min="1" max="10" value="5"
                        showTickMarks="true" showTickLabels="true"
                        style="
                            -fx-background-color: transparent;
                            -fx-control-inner-background: #333;
                            -fx-accent: #ff6600;
                        "/>
            </HBox>
        </StackPane>
    </bottom>

</BorderPane>
